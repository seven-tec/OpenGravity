# OpenGravity Core - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram user IDs
# Example: "123456789,987654321"
TELEGRAM_ALLOWED_USER_IDS=123456789

# ============================================
# LLM PROVIDERS (Groq + OpenRouter Fallback)
# ============================================
GROQ_API_KEY=your_groq_api_key_here

# Get from https://openrouter.ai/keys (optional - fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Get from https://apilaplas.com (required for vision)
LAPLAS_API_KEY=your_laplas_api_key_here

# Groq Model (recommended: llama-3.3-70b-versatile for speed/quality)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter Model (fallback - used when Groq rate limits)
OPENROUTER_MODEL=anthropic/claude-3-haiku

# ============================================
# AGENT CONFIGURATION
# ============================================
# Maximum messages to include in context window
MAX_CONTEXT_MESSAGES=10

# Maximum iterations in the agent loop (prevents infinite loops)
MAX_ITERATIONS=5

# System prompt for the agent personality
AGENT_SYSTEM_PROMPT=Eres "OpenGravity", la Arquitecta de Software Senior y mano derecha de Pablo. Tu personalidad es impecable, técnica, directa y con un sarcasmo elegante. Hablas con modismos de Chile y Argentina (fiera, crack, boludo, al toque). MODOS: 1) ENTRADA DE VOZ: Ignora errores fonéticos. 2) SALIDA DE VOZ: Sé extremadamente conciso (max 2-3 oraciones). 3) HERRAMIENTAS: Tenés acceso a Firestore (OMNI-TOOL), VISION (image_generation) y RESEARCH (google_search). REGLA CRÍTICA: Si te piden una imagen, USÁ la herramienta image_generation. NO des explicaciones de que eres un modelo de texto. Confía en tus herramientas.

# ============================================
# DATABASE & STORAGE
# ============================================
# Path to SQLite database file
DB_PATH=./data/opengravity.db

# ============================================
# AUDIO SERVICES (Future Integration)
# ============================================
# ElevenLabs API Key (for TTS)
ELEVENLABS_API_KEY=

# OpenAI Whisper API Key (for STT)
WHISPER_API_KEY=

# Default voice ID for ElevenLabs TTS
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# SHELL EXECUTION (Security)
# ============================================
# Comma-separated list of allowed shell commands (regex patterns)
# SHELL_ALLOWED_PATTERNS=^ls,^pwd,^cat,^echo,^node,^npm

# Maximum shell command timeout in milliseconds
SHELL_TIMEOUT_MS=30000
