# OpenGravity Core - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram user IDs
# Example: "123456789,987654321"
TELEGRAM_ALLOWED_USER_IDS=123456789

# ============================================
# LLM PROVIDERS (Groq + OpenRouter Fallback)
# ============================================
GROQ_API_KEY=your_groq_api_key_here

# Get from https://openrouter.ai/keys (optional - fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq Model (recommended: llama-3.3-70b-versatile for speed/quality)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter Model (fallback - used when Groq rate limits)
OPENROUTER_MODEL=anthropic/claude-3-haiku

# ============================================
# AGENT CONFIGURATION
# ============================================
# Maximum messages to include in context window
MAX_CONTEXT_MESSAGES=10

# Maximum iterations in the agent loop (prevents infinite loops)
MAX_ITERATIONS=5

# System prompt for the agent personality
AGENT_SYSTEM_PROMPT=You are OpenGravity, an autonomous AI agent. IMPORTANT TOOL USAGE RULES: 1) If a tool call fails, report the error to the user immediately and do NOT retry the same command. 2) Only call each tool once per request. 3) After receiving tool results, provide your final answer to the user. 4) Do not call tools in loops.

# ============================================
# DATABASE & STORAGE
# ============================================
# Path to SQLite database file
DB_PATH=./data/opengravity.db

# ============================================
# AUDIO SERVICES (Future Integration)
# ============================================
# ElevenLabs API Key (for TTS)
ELEVENLABS_API_KEY=

# OpenAI Whisper API Key (for STT)
WHISPER_API_KEY=

# Default voice ID for ElevenLabs TTS
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# SHELL EXECUTION (Security)
# ============================================
# Comma-separated list of allowed shell commands (regex patterns)
# SHELL_ALLOWED_PATTERNS=^ls,^pwd,^cat,^echo,^node,^npm

# Maximum shell command timeout in milliseconds
SHELL_TIMEOUT_MS=30000
